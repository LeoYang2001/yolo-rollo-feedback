# Copy these into Vercel → Project → Settings → Environment Variables.
# This app is standalone (NOT wired to the ordering system); it only
# needs Firebase (same project as ordering) + the reward/email vars.

# Firebase Admin SDK service-account credentials
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBg...\n-----END PRIVATE KEY-----\n"

# ── Google review nudge (client-side, build-time) ──────────────────
# Where high raters (avg > 4.5/5) are sent to leave a public review.
# Must be prefixed VITE_ to be exposed to the browser bundle.
# Get yours: Google Business Profile → Ask for reviews → copy the link
# (looks like https://g.page/r/XXXXXXXXXXXX/review or a maps.app.goo.gl
# /search short link). Leave blank to disable the nudge.
VITE_GOOGLE_REVIEW_URL=https://g.page/r/your-place-id/review

# Staff PIN for the admin dashboard at /admin
FEEDBACK_ADMIN_PIN=808080

# Random secret (≥32 chars) used to sign admin session tokens.
# Rotate this to log everyone out instantly.
FEEDBACK_SESSION_SECRET=replace-me-with-a-long-random-string

# ── Reward / gift card delivery ─────────────────────────────────────
# Resend API key (https://resend.com — free tier covers 3K emails/mo)
RESEND_API_KEY=re_your_resend_key_here

# Verified sender. Must match a domain you've verified in Resend.
# Format: "Display Name <you@yourdomain.com>"
FROM_EMAIL=Yolo Rollo <hi@yolorollo.com>

# Max gift cards issued per day. Set to 0 to disable the reward path
# entirely without redeploying (feedback writes still work).
REWARD_DAILY_CAP=50

# Reward amount in cents. Default 100 = $1.00.
REWARD_AMOUNT_CENTS=100

# ── Clover Ecommerce Gift Card API (optional) ──────────────────────
# If these THREE are all set, we mint real Clover virtual gift cards
# via the /v1/activate endpoint. If ANY is missing or the call fails,
# we fall back to generating a YR-XXXX-XXXX custom code (staff applies
# $1 off manually). Flip between modes by setting/unsetting these vars.
#
# Prereqs on Clover side before this works:
#   1. Merchant Dashboard → Ecommerce Payments → enable Gift card payments
#   2. Create a denominated promo code for the reward amount you want
#   3. Generate an Ecommerce API token (separate from your REST token):
#      https://docs.clover.com/dev/docs/create-ecommerce-api-tokens

# https://scl.clover.com (production) or https://scl-sandbox.dev.clover.com (sandbox)
CLOVER_ECOMM_API_BASE=https://scl.clover.com
# Private Ecommerce API token / PAKMS key (NOT the REST API token).
CLOVER_ECOMM_API_TOKEN=
# Pre-configured promotion code from your Clover dashboard.
CLOVER_GIFT_CARD_PROMO_CODE=
